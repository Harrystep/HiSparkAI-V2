+int CeluInt8(const int8_t *src, int length, int8_t *dst, int8_t *table) {
+  for (int i = 0; i < length; i++) {
+    const int8_t input_value = src[i];
+    uint8_t index = (uint8_t)input_value;
+    dst[i] = table[index];
+  }
+  return NNACL_OK;
+}
