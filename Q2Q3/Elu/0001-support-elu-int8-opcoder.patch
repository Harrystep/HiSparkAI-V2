+
+/**
+ * @brief Initialize ELu lookup table
+ *
+ * Pre-computes the ELu lookup table for all 256 possible int8 input values.
+ * Uses the formula: y = x > 0 ? x : alpha * (exp(x) - 1)
+ *
+ * @param quant_elu_param Pointer to EluQuantArg containing quantization parameters
+ * @param table Output array of 256 int8_t values (the lookup table)
+ * @return NNACL_OK on success, error code otherwise
+ */
+int EluInt8InitLUT(const EluQuantArg *quant_elu_param, int8_t *table);
+
+/**
+ * @brief Apply ELu activation using lookup table
+ *
+ * For each input element, uses its value as an index into the pre-computed
+ * lookup table to get the output value. This is O(1) per element with no
+ * floating-point operations at runtime.
+ *
+ * @param src Input int8 tensor data
+ * @param length Number of elements to process
+ * @param dst Output int8 tensor data
+ * @param table Pre-computed lookup table (256 entries)
+ * @return NNACL_OK on success
+ */
+int EluInt8(const int8_t *src, int length, int8_t *dst, const int8_t *table);
+
+#ifdef __cplusplus
+}
