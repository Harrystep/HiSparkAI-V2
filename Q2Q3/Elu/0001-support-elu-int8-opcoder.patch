--- /dev/null
+++ b/mindspore-lite/src/litert/kernel/cpu/nnacl_c/int8/elu_int8.c
@@ -0,0 +1,97 @@
+/**
+ * Copyright 2020 Huawei Technologies Co., Ltd
+ *
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ * http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+#include "nnacl_c/int8/elu_int8.h"
+#include <math.h>
+#include <limits.h>
+#include "nnacl_c/errorcode.h"
+
+/**
+ * Initialize ELu lookup table
+ *
+ * This function pre-computes the ELu output for all 256 possible int8 input values.
+ * The ELu formula is: y = x > 0 ? x : alpha * (exp(x) - 1)
+ *
+ * For each possible int8 input value (-128 to 127):
+ * 1. Dequantize to float: real_value = in_scale * (i - in_zp)
+ * 2. Apply ELu transform: transformed = real_value > 0 ? real_value : alpha * (exp(real_value) - 1)
+ * 3. Requantize to output: output = round(transformed / out_scale) + out_zp
+ * 4. Clip to int8 range and store in table
+ */
+int EluInt8InitLUT(const EluQuantArg *quant_elu_param, int8_t *table) {
+  if (quant_elu_param == NULL || table == NULL) {
+    return NNACL_NULL_PTR;
+  }
+
+  const float in_scale = quant_elu_param->in_args_.scale_;
+  const int32_t in_zp = quant_elu_param->in_args_.zp_;
+  const float out_scale = quant_elu_param->out_args_.scale_;
+  const int32_t out_zp = quant_elu_param->out_args_.zp_;
+  const float alpha = quant_elu_param->alpha_;
+  const float output_inverse_scale = 1.0f / out_scale;
+
+  const int32_t min_val = SCHAR_MIN;  // -128
+  const int32_t max_val = SCHAR_MAX;  // 127
+
+  // Iterate through all 256 possible int8 input values
+  for (int32_t i = min_val; i <= max_val; ++i) {
+    // Step 1: Dequantize input to float
+    const float real_input = in_scale * (i - in_zp);
+
+    // Step 2: Apply ELu transform
+    // ELu formula: y = x > 0 ? x : alpha * (exp(x) - 1)
+    float transformed;
+    if (real_input > 0.0f) {
+      transformed = real_input;
+    } else {
+      // For negative inputs: alpha * (exp(x) - 1)
+      transformed = alpha * (expf(real_input) - 1.0f);
+    }
+
+    // Step 3: Requantize to output scale
+    const float rescaled = roundf(transformed * output_inverse_scale);
+    int32_t quantized = (int32_t)(rescaled + out_zp);
+
+    // Step 4: Clip to valid int8 range
+    quantized = quantized > max_val ? max_val : quantized;
+    quantized = quantized < min_val ? min_val : quantized;
+
+    // Store in lookup table using unsigned index
+    table[(uint8_t)i] = (int8_t)quantized;
+  }
+
+  return NNACL_OK;
+}
+
+/**
+ * Apply ELu activation using lookup table
+ *
+ * This is the runtime function - very fast as it's just table lookups.
+ * No floating-point operations, no exp() calls at runtime.
+ */
+int EluInt8(const int8_t *src, int length, int8_t *dst, const int8_t *table) {
+  if (src == NULL || dst == NULL || table == NULL) {
+    return NNACL_NULL_PTR;
+  }
+
+  // For each element, use the input value as an index into the lookup table
+  // Cast to uint8_t ensures proper indexing for negative values
+  for (int i = 0; i < length; ++i) {
+    dst[i] = table[(uint8_t)src[i]];
+  }
+
+  return NNACL_OK;
+}
