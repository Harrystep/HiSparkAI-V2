+#ifndef MINDSPORE_LITE_SRC_RUNTIME_KERNEL_CPU_INT8_ELU_INT8_H_
+#define MINDSPORE_LITE_SRC_RUNTIME_KERNEL_CPU_INT8_ELU_INT8_H_
+
+#include <vector>
+#include <limits>
+#include "include/errorcode.h"
+#include "nnacl_c/fp32/activation_fp32.h"
+#include "nnacl_c/int8/elu_int8.h"
+#include "src/litert/lite_kernel.h"
+
+namespace mindspore::kernel {
+class EluInt8CPUKernel : public LiteKernel {
+ public:
+  EluInt8CPUKernel(OpParameter *parameter, const std::vector<lite::Tensor *> &inputs,
+                   const std::vector<lite::Tensor *> &outputs, const lite::InnerContext *ctx)
+      : LiteKernel(parameter, inputs, outputs, ctx) {}
+  ~EluInt8CPUKernel() override = default;
+
+  int Prepare() override;
+  int ReSize() override;
+  int Run() override;
+  int DoExecute(int task_id);
+
+ private:
+  // 256-entry lookup table for ELu activation
+  int8_t table_list_[256]{0};
+  EluQuantArg quant_elu_parm_ = {};
+};
+}  // namespace mindspore::kernel
+
+#endif  // MINDSPORE_LITE_SRC_RUNTIME_KERNEL_CPU_INT8_ELU_INT8_H_
diff --git a/mindspore-lite/src/litert/kernel/cpu/nnacl_c/int8/elu_int8.c b/mindspore-lite/src/litert/kernel/cpu/nnacl_c/int8/elu_int8.c
