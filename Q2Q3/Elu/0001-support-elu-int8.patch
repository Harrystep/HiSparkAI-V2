+namespace mindspore {
+class EluInt8Test : public ::testing::Test {
+ public:
+  EluInt8Test() {}
+  void SetUp() override {
+    // 初始化量化参数
+    quant_parm_.in_args_.scale_ = 0.1f;
+    quant_parm_.in_args_.zp_ = 0;
+    quant_parm_.out_args_.scale_ = 0.1f;
+    quant_parm_.out_args_.zp_ = 0;
+    quant_parm_.alpha_ = 1.0f;
