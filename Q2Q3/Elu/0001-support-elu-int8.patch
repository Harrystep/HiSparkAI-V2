+int EluInt8Coder::Prepare(CoderContext *context) {
+  quant_elu_parm_.thread_num_ = 1;  // Micro 场景通常单线程
+  quant_elu_parm_.alpha_ = reinterpret_cast<ActivationParameter *>(parameter_)->alpha_;
+
+  auto *input_tensor = input_tensors_.at(kInputIndex);
+  auto in_quant_args = input_tensor->quant_params();
+  MS_CHECK_TRUE_MSG(!in_quant_args.empty(), RET_ERROR, "Input quant param cannot be empty.");
+  quant_elu_parm_.in_args_.scale_ = static_cast<float>(in_quant_args.front().scale);
+  quant_elu_parm_.in_args_.zp_ = in_quant_args.front().zeroPoint;
+
+  auto *out_tensor = output_tensors_.at(kOutputIndex);
+  auto out_quant_args = out_tensor->quant_params();
+  MS_CHECK_TRUE_MSG(!out_quant_args.empty(), RET_ERROR, "Output quant param cannot be empty.");
+  quant_elu_parm_.out_args_.scale_ = static_cast<float>(out_quant_args.front().scale);
+  quant_elu_parm_.out_args_.zp_ = out_quant_args.front().zeroPoint;
+
+  MS_CHECK_GT(input_tensor->ElementsNum(), 0, RET_ERROR);
+  quant_elu_parm_.element_num = input_tensor->ElementsNum();
+
+  // 初始化 LUT
+  int ret = EluInt8InitLUT(&quant_elu_parm_);
+  if (ret != NNACL_OK) {
+    MS_LOG(ERROR) << "EluInt8InitLUT failed: " << ret;
+    return RET_ERROR;
+  }
+
+  return RET_OK;
+}
+
+int EluInt8Coder::DoCode(CoderContext *const context) {
+  Collect(context,
+          {
+            "nnacl_c/int8/elu_int8.h",
+          },
+          {
+            "elu_int8.c",
+          });
+
+  NNaclInt8Serializer code;
+
+  // 生成 LUT 初始化代码
+  code << "\n// ELU INT8 LUT initialization\n";
+  code.CodeStruct("elu_quant_arg", quant_elu_parm_);
+  code << "EluInt8InitLUT(&elu_quant_arg);\n\n";
+
+  // 生成计算代码
+  code.CodeFunction("DoEluInt8", input_tensor_, output_tensor_, "&elu_quant_arg", 0);
+
+  // 添加清理代码（在函数结束时）
+  code << "\n// Cleanup LUT memory\n";
+  code.CodeFunction("EluInt8FreeLUT", "&elu_quant_arg");
+
+  context->AppendCode(code.str());
+  return RET_OK;
+}
+
+REG_OPERATOR_CODER(kAllTargets, kNumberTypeInt8, PrimitiveType_Activation, CPUOpCoderCreator<EluInt8Coder>)
+}  // namespace mindspore::lite::micro::nnacl
