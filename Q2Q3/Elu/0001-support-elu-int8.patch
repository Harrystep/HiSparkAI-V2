+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+#include "nnacl_c/int8/elu_int8.h"
+#include "nnacl_c/errorcode.h"
+#include <math.h>
+#include <stdlib.h>
+#include <string.h>
+
+/**
+ * @brief 初始化 ELU INT8 查找表
+ *
+ * 为所有 256 个可能的 INT8 输入值预计算对应的 ELU 输出
+ * 这是在初始化阶段完成的，推理阶段只需查表
+ */
+int EluInt8InitLUT(EluInt8QuantArg *quant_arg) {
+  if (quant_arg == NULL) {
+    return NNACL_NULL_PTR;
+  }
+
+  // 分配 LUT 内存 (256 bytes)
+  if (quant_arg->lut_table_ == NULL) {
+    quant_arg->lut_table_ = (int8_t *)malloc(256 * sizeof(int8_t));
+    if (quant_arg->lut_table_ == NULL) {
+      return NNACL_NO_MEMORY;
+    }
+  }
+
+  // 获取量化参数
+  float input_scale = quant_arg->in_args_.scale_;
+  int input_zp = quant_arg->in_args_.zp_;
+  float output_scale = quant_arg->out_args_.scale_;
+  int output_zp = quant_arg->out_args_.zp_;
+  float alpha = quant_arg->alpha_;
+  const float output_inverse_scale = 1.0f / output_scale;
+
+  // 生成 LUT: 对所有 256 个可能的 INT8 输入值
+  for (int i = 0; i < 256; i++) {
+    // 将索引 [0, 255] 映射到实际的 int8 值 [-128, 127]
+    int8_t input_val = (int8_t)(i - 128);
+
+    // 步骤1: 反量化到浮点域 (仅在此阶段使用浮点)
+    float input_real = ((int)input_val - input_zp) * input_scale;
+
+    // 步骤2: 应用 ELU 激活函数
+    // ELU(x) = x                  if x > 0
+    //        = alpha * (exp(x) - 1) if x <= 0
+    float output_real;
+    if (input_real > 0) {
+      output_real = input_real;
+    } else {
+      // 使用 expm1(x) = exp(x) - 1 提高小数值精度
+      output_real = expm1f(input_real) * alpha;
+    }
+
+    // 步骤3: 量化回 int8
+    int32_t output_tmp = (int32_t)round(output_real * output_inverse_scale) + output_zp;
+
+    // 步骤4: 饱和截断到 int8 范围
+    if (output_tmp > 127) {
+      output_tmp = 127;
+    } else if (output_tmp < -128) {
+      output_tmp = -128;
+    }
+
+    quant_arg->lut_table_[i] = (int8_t)output_tmp;
+  }
+
+  quant_arg->table_initialized_ = 1;
+  return NNACL_OK;
+}
+
+/**
+ * @brief 释放 ELU INT8 查找表内存
+ */
+void EluInt8FreeLUT(EluInt8QuantArg *quant_arg) {
+  if (quant_arg != NULL && quant_arg->lut_table_ != NULL) {
+    free(quant_arg->lut_table_);
+    quant_arg->lut_table_ = NULL;
+    quant_arg->table_initialized_ = 0;
+  }
+}
+
+/**
+ * @brief ELU INT8 计算函数 (使用 LUT)
+ *
+ * 推理阶段：纯整数查表，无浮点计算
+ * 将输入值作为索引直接查找预计算的输出值
+ */
+int DoEluInt8(const int8_t *inputs, int8_t *outputs, const EluInt8QuantArg *quant_arg, int task_id) {
+  if (quant_arg == NULL || inputs == NULL || outputs == NULL) {
+    return NNACL_NULL_PTR;
+  }
+
+  if (quant_arg->lut_table_ == NULL) {
+    return NNACL_NULL_PTR;
+  }
+
+  const int8_t *lut = quant_arg->lut_table_;
+
+  // 多线程并行处理
+  // 纯整数查表操作，无浮点计算
+  for (int i = task_id; i < quant_arg->element_num; i += quant_arg->thread_num_) {
+    // 将 signed int8 转换为 unsigned index
+    // -128 → 0, -127 → 1, ..., 0 → 128, ..., 127 → 255
+    // 利用 C 语言的无符号溢出语义实现
+    uint8_t idx = (uint8_t)inputs[i];
+    outputs[i] = lut[idx];
+  }
+
+  return NNACL_OK;
+}
