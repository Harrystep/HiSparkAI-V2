+/**
+ * @brief ELU INT8 量化参数结构体
+ *
+ * 使用 LUT (Lookup Table) 方案实现纯 INT8 计算
+ * 在 Prepare 阶段生成 256 元素的查找表，推理阶段直接查表
+ */
+typedef struct EluInt8QuantArg {
+  QuantArg in_args_;       /* 输入量化参数 */
+  QuantArg out_args_;      /* 输出量化参数 */
+  float alpha_;            /* ELU alpha 参数 */
+  int8_t *lut_table_;      /* 查找表指针 (256 元素) */
+  int table_initialized_;  /* 表是否已初始化标志 */
+  int element_num;         /* 元素数量 */
+  int thread_num_;         /* 线程数 */
+} EluInt8QuantArg;
+
+/**
+ * @brief 初始化 ELU INT8 查找表
+ *
+ * 在 Prepare 阶段调用，生成 256 个可能的 INT8 输入对应的输出
+ * 这是唯一使用浮点计算的阶段
+ *
+ * @param quant_arg ELU 量化参数结构体指针
+ * @return NNACL_OK 成功，其他值表示错误
+ */
+int EluInt8InitLUT(EluInt8QuantArg *quant_arg);
+
+/**
+ * @brief 释放 ELU INT8 查找表内存
+ *
+ * @param quant_arg ELU 量化参数结构体指针
+ */
+void EluInt8FreeLUT(EluInt8QuantArg *quant_arg);
+
+/**
+ * @brief ELU INT8 计算函数 (使用 LUT)
+ *
+ * 纯整数查表操作，推理阶段无浮点计算
+ *
+ * @param inputs 输入 int8 数据指针
+ * @param outputs 输出 int8 数据指针
+ * @param quant_arg ELU 量化参数结构体指针
+ * @param task_id 任务 ID，用于多线程并行处理
+ * @return NNACL_OK 成功，其他值表示错误
+ */
+int DoEluInt8(const int8_t *inputs, int8_t *outputs, const EluInt8QuantArg *quant_arg, int task_id);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif  // NNACL_INT8_ELU_INT8_H_
