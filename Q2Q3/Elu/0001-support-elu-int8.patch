+#include "src/litert/kernel_registry.h"
+
+using mindspore::kernel::KERNEL_ARCH;
+using mindspore::lite::KernelRegistrar;
+using mindspore::lite::RET_ERROR;
+using mindspore::lite::RET_OK;
+using mindspore::schema::PrimitiveType_Activation;
+
+namespace mindspore::kernel {
+namespace {
+int EluInt8Run(void *cdata, int task_id, float, float) {
+  if (cdata == nullptr) {
+    MS_LOG(ERROR) << "input cdata is nullptr!";
+    return RET_ERROR;
+  }
+  auto elu = reinterpret_cast<EluInt8CPUKernel *>(cdata);
+  auto ret = elu->DoExecute(task_id);
+  if (ret != RET_OK) {
+    MS_LOG(ERROR) << "EluInt8Run task_id " << task_id << " failed.";
+    return ret;
+  }
+  return RET_OK;
+}
+}  // namespace
+
+int EluInt8CPUKernel::Prepare() {
+  CHECK_LESS_RETURN(in_tensors_.size(), C1NUM);
+  CHECK_LESS_RETURN(out_tensors_.size(), C1NUM);
+  CHECK_NULL_RETURN(in_tensors_[0]);
+  CHECK_NULL_RETURN(out_tensors_[0]);
+
+  if (in_tensors_[0]->data_type() != mindspore::kNumberTypeInt8 ||
+      out_tensors_[0]->data_type() != mindspore::kNumberTypeInt8) {
+    MS_LOG(ERROR) << "Datatype error, input0 data_type is " << in_tensors_[0]->data_type()
+                  << ", output data_type is " << out_tensors_[0]->data_type();
+    return RET_ERROR;
+  }
+
+  // 设置量化参数
+  quant_elu_parm_.thread_num_ = op_parameter_->thread_num_;
+  quant_elu_parm_.alpha_ = reinterpret_cast<ActivationParameter *>(op_parameter_)->alpha_;
+
+  auto *input_tensor = in_tensors_.at(kInputIndex);
+  auto in_quant_args = input_tensor->quant_params();
+  MS_CHECK_TRUE_MSG(!in_quant_args.empty(), RET_ERROR, "Input quant param cannot be empty.");
+  quant_elu_parm_.in_args_.scale_ = static_cast<float>(in_quant_args.front().scale);
+  quant_elu_parm_.in_args_.zp_ = in_quant_args.front().zeroPoint;
+
+  auto *out_tensor = out_tensors_.at(kOutputIndex);
+  auto out_quant_args = out_tensor->quant_params();
+  MS_CHECK_TRUE_MSG(!out_quant_args.empty(), RET_ERROR, "Output quant param cannot be empty.");
+  quant_elu_parm_.out_args_.scale_ = static_cast<float>(out_quant_args.front().scale);
+  quant_elu_parm_.out_args_.zp_ = out_quant_args.front().zeroPoint;
+
+  if (!InferShapeDone()) {
+    return RET_OK;
+  }
+  return ReSize();
+}
+
+EluInt8CPUKernel::~EluInt8CPUKernel() {
+  // 释放 LUT 内存
+  EluInt8FreeLUT(&quant_elu_parm_);
+}
+
+int EluInt8CPUKernel::ReSize() {
+  auto *input_tensor = in_tensors_.at(kInputIndex);
+  MS_CHECK_GT(input_tensor->ElementsNum(), 0, RET_ERROR);
+  quant_elu_parm_.element_num = input_tensor->ElementsNum();
+
+  // 初始化或重新初始化 LUT (仅在形状变化时需要)
+  // 如果 LUT 已初始化且量化参数未变，可以跳过
+  if (!quant_elu_parm_.table_initialized_) {
+    int ret = EluInt8InitLUT(&quant_elu_parm_);
+    if (ret != NNACL_OK) {
+      MS_LOG(ERROR) << "EluInt8InitLUT failed: " << ret;
+      return RET_ERROR;
+    }
+  }
+
+  return RET_OK;
+}
+
+int EluInt8CPUKernel::Run() {
+  auto ret = ParallelLaunch(this->ms_context_, EluInt8Run, this, op_parameter_->thread_num_);
+  if (ret != RET_OK) {
+    MS_LOG(ERROR) << "EluInt8 Run failed.";
+  }
+  return ret;
+}
+
+int EluInt8CPUKernel::DoExecute(int task_id) {
+  auto input_tensor = in_tensors_.at(kInputIndex);
+  auto out_tensor = out_tensors_.at(kOutputIndex);
+  int8_t *input_data = reinterpret_cast<int8_t *>(input_tensor->data());
+  int8_t *output_data = reinterpret_cast<int8_t *>(out_tensor->data());
+  MS_ASSERT(input_data);
+  MS_ASSERT(output_data);
+
+  // 纯整数查表操作，无浮点计算
+  auto ret = DoEluInt8(input_data, output_data, &quant_elu_parm_, task_id);
+  if (ret != NNACL_OK) {
+    MS_LOG(ERROR) << "DoEluInt8 failed: " << ret;
+    return RET_ERROR;
+  }
+  return RET_OK;
+}
+
+REG_KERNEL(kCPU, kNumberTypeInt8, PrimitiveType_Activation, LiteKernelCreator<EluInt8CPUKernel>)
+}  // namespace mindspore::kernel
