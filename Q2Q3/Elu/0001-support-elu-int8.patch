+// 测试精度验证：与 FP32 结果对比
+TEST_F(EluInt8Test, EluAccuracyCheck) {
+  quant_parm_.element_num = 9;
+  ASSERT_EQ(NNACL_OK, EluInt8InitLUT(&quant_parm_));
+
+  std::vector<int8_t> input = {-100, -50, -20, -5, 0, 5, 20, 50, 100};
+  std::vector<int8_t> output(9);
+  std::vector<int8_t> benchmark(9);
+
+  // 生成 benchmark 数据（使用 FP32 ELU 计算）
+  for (int i = 0; i < 9; i++) {
+    float input_real = input[i] * quant_parm_.in_args_.scale_;
+    float output_real;
+    if (input_real > 0) {
+      output_real = input_real;
+    } else {
+      output_real = expm1f(input_real);
+    }
+    int8_t expected = static_cast<int8_t>(
+        std::round(output_real / quant_parm_.out_args_.scale_) + quant_parm_.out_args_.zp_);
+    expected = std::max(-128, std::min(127, static_cast<int>(expected)));
+    benchmark[i] = expected;
+  }
+
+  // 调用 INT8 ELU
+  int ret = DoEluInt8(input.data(), output.data(), &quant_parm_, 0);
+  ASSERT_EQ(ret, NNACL_OK);
+
+  // 输出对比结果
+  std::cout << "EluInt8Test accuracy comparison:\n";
+  std::cout << "input:    ";
+  std::for_each(input.begin(), input.end(), [](int8_t v) { std::cout << std::setw(4) << (int)v << " "; });
+  std::cout << "\noutput:   ";
+  std::for_each(output.begin(), output.end(), [](int8_t v) { std::cout << std::setw(4) << (int)v << " "; });
+  std::cout << "\nbenchmark:";
+  std::for_each(benchmark.begin(), benchmark.end(), [](int8_t v) { std::cout << std::setw(4) << (int)v << " "; });
+  std::cout << "\n";
+
+  // 验证 LUT 结果与 FP32 计算结果一致
+  for (int i = 0; i < 9; i++) {
+    EXPECT_EQ(output[i], benchmark[i]) << "Mismatch at index " << i
+                                         << ": input=" << (int)input[i]
+                                         << ", output=" << (int)output[i]
+                                         << ", expected=" << (int)benchmark[i];
+  }
+}
