+
+  // 清理
+  EluInt8FreeLUT(&quant_parm_);
+  EXPECT_EQ(quant_parm_.lut_table_, nullptr);
+
+  // 重复清理应该是安全的
+  EluInt8FreeLUT(&quant_parm_);
+  EXPECT_EQ(quant_parm_.lut_table_, nullptr);
