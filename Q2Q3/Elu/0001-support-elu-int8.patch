+  ASSERT_EQ(ret, NNACL_OK);
+  ASSERT_NE(quant_parm_.lut_table_, nullptr);
+  ASSERT_EQ(quant_parm_.table_initialized_, 1);
+
+  // 验证 LUT 的一些关键点
+  // 对于正值输入，输出应接近输入
+  // input=0 (index 128) → output ≈ 0
+  // input=127 (index 255) → output ≈ 127 (饱和)
+  EXPECT_GE(quant_parm_.lut_table_[128], -1);   // input=0
+  EXPECT_LE(quant_parm_.lut_table_[128], 1);
+}
