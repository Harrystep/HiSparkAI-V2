+#include "coder/opcoders/nnacl/int8/hardsigmoid_int8_coder.h"
+#include <limits>
+#include <algorithm>
+#include "coder/log.h"
+#include "include/errorcode.h"
+#include "coder/opcoders/file_collector.h"
+#include "coder/opcoders/serializers/nnacl_serializer/nnacl_int8_serializer.h"
+#include "nnacl_c/activation_parameter.h"
+
+namespace mindspore::lite::micro::nnacl {
+constexpr auto kInt8Range = 256;
+
+void CalculateHardSigmoidTable(int8_t *table, const float input_scale, const int32_t input_zp,
+                               const float output_scale, const int32_t output_zp, const float alpha,
+                               const float beta) {
+  constexpr int32_t min_value = std::numeric_limits<int8_t>::min();
+  constexpr int32_t max_value = std::numeric_limits<int8_t>::max();
+
+  for (int i = min_value; i <= max_value; ++i) {
+    const float real_input_value = input_scale * (i - input_zp);
+    const float hardsigmoid_value = std::max(0.0f, std::min(1.0f, alpha * real_input_value + beta));
+    const int32_t quantized = static_cast<int32_t>(std::round(hardsigmoid_value / output_scale) + output_zp);
+    auto out_value = static_cast<int8_t>(std::max(std::min(quantized, max_value), min_value));
+    auto index = static_cast<uint8_t>(static_cast<int8_t>(i));
+    table[index] = out_value;
+  }
+}
+
+int HardSigmoidInt8Coder::Prepare(CoderContext *const context) {
+  table_list_ = static_cast<int8_t *>(allocator_->Malloc(kNumberTypeInt8, kInt8Range, kOfflinePackWeight));
+  MS_CHECK_PTR(table_list_);
+
+  const float input_scale = input_tensor_->quant_params().at(0).scale;
+  const int32_t input_zp = input_tensor_->quant_params().at(0).zeroPoint;
+  const float output_scale = output_tensor_->quant_params().at(0).scale;
+  const int32_t output_zp = output_tensor_->quant_params().at(0).zeroPoint;
+
+  auto *param = reinterpret_cast<ActivationParameter *>(parameter_);
+  float alpha = param->alpha_;
+  float beta = param->beta_;
+  CalculateHardSigmoidTable(table_list_, input_scale, input_zp, output_scale, output_zp, alpha, beta);
+  return RET_OK;
+}
+
+int HardSigmoidInt8Coder::DoCode(CoderContext *const context) {
+  Collect(context,
+          {
+            "nnacl_c/int8/hardsigmoid_int8.h",
+          },
+          {
+            "hardsigmoid_int8.c",
+          });
+
+  NNaclInt8Serializer code;
+
+  int length = static_cast<int>(input_tensor_->ElementsNum());
+  code.CodeFunction("HardSigmoidInt8", input_tensor_, length, output_tensor_, table_list_);
+
+  context->AppendCode(code.str());
+
+  return RET_OK;
+}
+}  // namespace mindspore::lite::micro::nnacl
