+#include "coder/opcoders/nnacl/fp32/tril_fp32_coder.h"
+#include "nnacl_c/fp32/triu_tril_fp32.h"
+#include "coder/opcoders/file_collector.h"
+#include "coder/opcoders/serializers/nnacl_serializer/nnacl_fp32_serializer.h"
+
+using mindspore::schema::PrimitiveType_Tril;
+
+namespace mindspore::lite::micro::nnacl {
+int TrilFP32Coder::DoCode(CoderContext *const context) {
+  // Extract k value from optional second input
+  int64_t k = 0;
+  if (input_tensors_.size() > 1 && input_tensors_[1] != nullptr && input_tensors_[1]->data() != nullptr) {
+    auto data_type = input_tensors_[1]->data_type();
+    if (data_type == kNumberTypeInt32 || data_type == kNumberTypeInt) {
+      k = static_cast<int64_t>(*reinterpret_cast<int32_t *>(input_tensors_[1]->data()));
+    } else if (data_type == kNumberTypeInt64) {
+      k = *reinterpret_cast<int64_t *>(input_tensors_[1]->data());
+    } else {
+      MS_LOG(ERROR) << "Unsupported k tensor data type: " << data_type;
+      return RET_ERROR;
+    }
+  }
+
+  // Compute shape dimensions: mul = batch count, height/width = last 2 dims
+  auto &shape = input_tensor_->shape();
+  int ndim = static_cast<int>(shape.size());
+  if (ndim < 2) {
+    MS_LOG(ERROR) << "Tril requires input tensor with at least 2 dimensions, but got " << ndim;
+    return RET_ERROR;
+  }
+  int64_t height = shape[ndim - 2];
+  int64_t width = shape[ndim - 1];
+  int64_t mul = 1;
+  for (int i = 0; i < ndim - 2; i++) {
+    mul *= shape[i];
+  }
+
+  Collect(context,
+          {
+            "nnacl_c/fp32/triu_tril_fp32.h",
+          },
+          {
+            "triu_tril_fp32.c",
+          });
+
+  NNaclFp32Serializer code;
+  code.CodeFunction("TrilByte4", input_tensor_, output_tensor_, k, height, width, mul);
+  context->AppendCode(code.str());
+  return lite::RET_OK;
+}
+
+REG_OPERATOR_CODER(kAllTargets, kNumberTypeFloat32, PrimitiveType_Tril, CPUOpCoderCreator<TrilFP32Coder>)
+}  // namespace mindspore::lite::micro::nnacl
